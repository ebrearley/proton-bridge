# Proton Bridge ports
#
# Change these if the default ports conflict with something already running on
# your Docker host.
PROTON_BRIDGE_UI_PORT=3000
PROTON_BRIDGE_IMAP_PORT=1143
PROTON_BRIDGE_SMTP_PORT=1025

# Optional trusted TLS for IMAP/SMTP
#
# Leave these blank to use Proton Bridge's default self-signed STARTTLS
# certificate. To use a trusted certificate, clients must connect with a real
# public DNS name covered by the certificate, such as mail.example.com. Raw LAN
# IPs and .local names cannot be registered with Let's Encrypt.
PROTON_BRIDGE_TLS_DOMAIN=
PROTON_BRIDGE_TLS_CERTS_PATH=proton_bridge_certs

# Optional Let's Encrypt helper
#
# DNS-01 is recommended for LAN deployments because it does not require opening
# port 80 to the internet. Put DNS provider credentials in .env.acme, not here.
LETSENCRYPT_EMAIL=
LETSENCRYPT_ACCEPT_TOS=true
LETSENCRYPT_SERVER=letsencrypt
# Common DNS providers: cloudflare, route53, digitalocean, porkbun, namecheap.
# See lego's DNS provider docs if your DNS host is not listed here.
PROTON_BRIDGE_ACME_DNS_PROVIDER=cloudflare
PROTON_BRIDGE_ACME_ENV_FILE=.env.acme
PROTON_BRIDGE_ACME_HTTP_PORT=80

# Advanced: override the certificate files mounted at PROTON_BRIDGE_TLS_CERTS_PATH.
# Leave these blank when using the Let's Encrypt helper.
BRIDGE_TLS_CERT_FILE=
BRIDGE_TLS_KEY_FILE=

# Development settings below. Most users do not need to change these.

# Proton Bridge Debian package version used when building the local Bridge
# image with docker compose up --build.
BRIDGE_DEB_VERSION=3.23.1-1

# Internal URL used by the UI container to reach the Bridge control API.
# Leave this as-is when using the provided docker-compose.yml.
BRIDGE_CONTROL_URL=http://proton-bridge:8081
